# Get these from https://api.slack.com/apps → your app

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token   # needed for Socket Mode

PORT=3000
DASHBOARD_URL=http://localhost:3000   # public URL for the dashboard (used in App Home)
DATA_DIR=                             # optional: stable path for SQLite DB (e.g. /home/forge/data)
